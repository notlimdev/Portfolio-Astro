---
// src/components/head/elementsHeader/Banner.astro
import BannerClipPath from './BannerClipPath'
import Presentation from './Presentation'
import CTAButton from './CTAButton'
import ImgProfile from "../../../assets/milton-vergara-notlimdev.png"
import { Image } from 'astro:assets'
---

<div class="banner-container relative z-0
            h-1/3 w-full
            sm:w-[95%] sm:h-1/2
            md:w-[95%] md:h-3/5
            lg:h-3/4 lg:w-[95%] lg:mt-0
            xl:h-4/5 xl:w-[95%]
            2xl:h-[85%] 2xl:w-[90%]
            max-sm:absolute max-sm:h-4/5 max-sm:w-[95%] max-sm:top-8">

  {/* Fondo con clip path y blur */}
  <div
    class="z-0 bg-slate-800 absolute h-full w-full left-0 top-0
           [clip-path:url(#my-clip-path-desktop)]
           filter-[blur(100px)]"
  >
    <BannerClipPath client:only />

    {/* Bloques de color del fondo */}
    <div class="absolute top-0 xl:top-40 right-10
                bg-green-600 w-5/12 h-1/3 rounded
                2xl:h-3/12">
    </div>
    <div class="absolute top-20 left-0 lg:top-40 xl:top-40
                bg-cyan-600 w-1/3 h-1/4 rounded">
    </div>
    <div class="absolute bottom-0 left-0
                bg-purple-600 w-2/3 h-1/3 rounded 2xl:w-4/5">
    </div>
  </div>

  {/* Contenido principal */}
  <div class="absolute w-full h-full">
    <Presentation />

    {/* Imagen de perfil */}
    <div class="absolute rounded-3xl shadow-2xl
                border-r-8 border-indigo-300
                w-100 h-100 right-20 top-48
                max-sm:w-16 max-sm:h-16 max-sm:top-16 max-sm:right-8
                max-sm:border-r-2
                sm:w-40 sm:h-40 sm:top-28 sm:right-8
                md:w-56 md:h-56 md:top-40
                lg:w-72 lg:h-72 lg:top-52
                xl:w-96 xl:h-96 xl:top-44 xl:right-10
                2xl:w-100 2xl:h-100 2xl:right-28 2xl:top-48">
      <Image
        src={ImgProfile}
        alt="Foto de perfil Milton Vergara"
        class="bg-cover w-full h-full rounded-full drop-shadow-2xl shadow-lg shadow-indigo-300 drop-shadow-indigo-400"
        width={400}
        height={400}
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </div>

  {/* CTA Button */}
  <div class="absolute w-[96%] h-full z-10
              flex flex-row justify-center items-center
              md:justify-start">
    <CTAButton
      label="Descargar CV"
      variant="gradient-fill"
      client:idle
      href="/curriculum"
      target="_blank"
    />
  </div>

</div>
