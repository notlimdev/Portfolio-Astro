---
import "../styles/curriculum.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Curriculum · notlimdev",
  description = "Curriculum modular con layout y tema independientes dentro del portfolio.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>
